# Copy to .env.local and fill in values

# Required: transcription (AssemblyAI)
ASSEMBLYAI_API_KEY=

# Required: Turso / libSQL database
TURSO_DB=libsql://
TURSO_TOKEN=

# Required: speaker identification (Azure OpenAI)
AZURE_OPENAI_ENDPOINT=https://{resource}.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_API_KEY=

# Production: Vercel cron job auth (auto-set by Vercel)
# CRON_SECRET=

# Eval system (not needed for the web app)
ELEVENLABS_API_KEY=

AZURE_SPEECH_KEY=
AZURE_SPEECH_ENDPOINT=
GEMINI_API_KEY=
HF_TOKEN=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_BUCKET=

# Optional: defaults to http://localhost:3000
NEXT_PUBLIC_BASE_URL=